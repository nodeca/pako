{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "doc",
  "includeVersion": true,
  "markdownLinkExternal": true,
  "sourceLinkExternal": true,
  "sourceLinkTemplate": "https://github.com/nodeca/pako/blob/{gitRevision:short}/{path}#L{line}",
  "navigationLinks": {
    "GitHub": "https://github.com/nodeca/pako"
  },
  "defaultCategory": "pako",
  "categoryOrder": ["pako", "*"],
  "sort": ["source-order"],
  "groupOrder": ["zlib options", "Extensions", "*"],
  "navigation": {
    "includeCategories": true
  }
}
