{
  "name": "pako",
  "description": "zlib port to javascript - fast, modularized, with browser support",
  "version": "2.2.0",
  "keywords": [
    "zlib",
    "deflate",
    "inflate",
    "gzip"
  ],
  "contributors": [
    "Andrei Tuputcyn (https://github.com/andr83)",
    "Vitaly Puzrin (https://github.com/puzrin)",
    "Friedel Ziegelmayer (https://github.com/dignifiedquire)",
    "Kirill Efimov (https://github.com/Kirill89)",
    "Jean-loup Gailly",
    "Mark Adler"
  ],
  "files": [
    "dist/",
    "src/"
  ],
  "license": "(MIT AND Zlib)",
  "repository": "nodeca/pako",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/puzrin"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/nodeca"
    }
  ],
  "module": "./dist/pako.esm.mjs",
  "exports": {
    ".": {
      "import": "./dist/pako.esm.mjs",
      "require": "./dist/pako.cjs"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./src/zlib/*": "./src/zlib/*",
    "./src/utils/*": "./src/utils/*"
  },
  "scripts": {
    "lint": "eslint . --ext .js,.mjs",
    "test": "npm run lint && node --test",
    "coverage": "npm run lint && c8 -r text -r html node --test",
    "build": "node support/build-dist.mjs",
    "build_fixtures": "node support/build_fixtures.mjs",
    "doc": "node support/build_doc.mjs",
    "gh-doc": "npm run doc && gh-pages -d doc -f",
    "prepack": "npm test && npm run build && npm run doc",
    "postpublish": "npm run gh-doc"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^7.13.0",
    "gh-pages": "^6.3.0",
    "ndoc": "^6.0.0",
    "vite": "^8.0.14"
  }
}
